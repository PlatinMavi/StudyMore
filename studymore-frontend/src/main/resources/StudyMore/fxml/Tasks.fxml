<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane fx:id="pageRoot" style="-fx-background-color: #000000;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="StudyMore.controllers.TasksController">
   <children>
      <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;">
         <content>
            <VBox spacing="40.0">
               <padding>
                  <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
               </padding>
               <children>
                  <AnchorPane prefHeight="80.0" style="-fx-background-color: #111; -fx-background-radius: 10; -fx-border-color: #222; -fx-border-radius: 10;">
                     <children>
                        <Label layoutX="20.0" layoutY="28.0" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 20;" text="TASKS &amp; SRS TRACKING" AnchorPane.leftAnchor="20.0" />
                        <Button fx:id="createTaskBtn" layoutX="600.0" layoutY="22.0" onAction="#handleCreateTask" prefHeight="35.0" style="-fx-background-color: white; -fx-text-fill: black; -fx-font-weight: bold; -fx-background-radius: 5;" text="+ CREATE TASK" AnchorPane.rightAnchor="20.0" />
                     </children>
                  </AnchorPane>

                  <VBox spacing="15.0">
                     <children>
                        <HBox alignment="CENTER_LEFT" maxWidth="-Infinity" prefHeight="40.0" style="-fx-background-color: #111; -fx-background-radius: 8; -fx-border-color: #222; -fx-border-radius: 8;">
                           <children>
                              <Label style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13;" text="NORMAL TASKS">
                                 <padding>
                                    <Insets left="20.0" right="20.0" />
                                 </padding>
                              </Label>
                           </children>
                        </HBox>
                        <FlowPane fx:id="normalTasksContainer" hgap="20.0" vgap="20.0" />
                     </children>
                  </VBox>

                  <VBox spacing="15.0">
                     <children>
                        <HBox alignment="CENTER_LEFT" maxWidth="-Infinity" prefHeight="40.0" style="-fx-background-color: #111; -fx-background-radius: 8; -fx-border-color: #222; -fx-border-radius: 8;">
                           <children>
                              <Label style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13;" text="SRS TASKS">
                                 <padding>
                                    <Insets left="20.0" right="20.0" />
                                 </padding>
                              </Label>
                           </children>
                        </HBox>
                        <FlowPane fx:id="srsTasksContainer" hgap="20.0" vgap="20.0" />
                     </children>
                  </VBox>
               </children>
            </VBox>
         </content>
      </ScrollPane>
   </children>
</StackPane>
